---
interface Props {
	size?: number
	class?: string
}

const { size = 24, class: className = 'text-foreground' } = Astro.props
---

<svg
	width={size}
	height={size}
	viewBox="0 0 24 24"
	class={className}
	aria-hidden="true"
>
	{
		[4, 12, 20].map((y, row) =>
			[4, 12, 20].map((x, col) => {
				const isCorner = (row === 0 || row === 2) && (col === 0 || col === 2)
				const isCenter = row === 1 && col === 1
				const type = isCorner
					? 'nav-dot-corner'
					: isCenter
						? 'nav-dot-center'
						: 'nav-dot-edge'
				return (
					<circle
						cx={x}
						cy={y}
						r="2"
						fill="currentColor"
						class:list={['nav-dot', type]}
						style={`--nav-dot-in-delay: ${(row + col) * 60}ms; --nav-dot-out-delay: ${(4 - row - col) * 60}ms`}
					/>
				)
			}),
		)
	}
</svg>
